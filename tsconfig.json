{
  "compileOnSave": true,
  "include": ["src/**/*.ts", "src/**/*.d.ts", "example/**/*.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022"],
    "noEmit": true,
    "experimentalDecorators": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  }
}
