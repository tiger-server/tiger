{
  "compileOnSave": true,
  "include": ["src/**/*.ts", "src/**/*.d.ts", "test/**/*.ts", "bin/**/*.ts"],
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "lib/"
  }
}
