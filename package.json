{
  "name": "tiger-server",
  "version": "0.6.2",
  "description": "Even simple than trigger",
  "main": "lib/src/index.js",
  "type": "module",
  "repository": "https://github.com/kenpusney/tiger",
  "author": "Kimmy Leo",
  "license": "MIT",
  "engines": {
    "node": ">=22.6.0"
  },
  "bin": {
    "tiger-server": "./lib/bin/tiger.js",
    "tiger": "./lib/bin/tiger.js"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "cron-parser": "^5.4.0",
    "express": "^5.1.0",
    "level": "^10.0.0",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "radash": "^12.1.1",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7",
    "dotenv": "^17.2.3",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "dotenv-cli": "^11.0.0",
    "sequelize-cli": "^6.6.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "example:bun": "dotenv -e .env -- bun bin/tiger.ts run test/runtime/runtest.ts",
    "example:node": "tsc && dotenv -e .example.env -- node ./lib/bin/tiger.js run ./lib/test/runtime/runtest.js",
    "distributed:bun": "dotenv -e .env -- bun bin/tiger.ts run test/runtime/runtest.ts -c .tigerconf.example.json",
    "distributed:node": "tsc && dotenv -e .example.env -- node ./lib/bin/tiger.js run ./lib/test/runtime/runtest.js -c .tigerconf.example.json",
    "build": "tsc"
  }
}
